# MongoDB connection string (get from MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quico?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Groq API key — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Next.js public URL (used for production)
NEXTAUTH_URL=http://localhost:3000
